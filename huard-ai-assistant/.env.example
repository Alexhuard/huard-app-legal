# ============================================
# HUARD AI Assistant - Variables d'environnement
# Copie ce fichier en .env et remplis les valeurs
# ============================================

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-xxxxx
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# --- Microsoft 365 / Outlook (MS Graph) ---
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_USER_EMAIL=alex@huard.fr

# --- Twilio WhatsApp Business (à remplir plus tard) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+33XXXXXXXXX

# --- WhatsApp perso POC (Baileys) ---
WA_PERSO_ENABLED=false
WA_PERSO_SESSION_DIR=./data/wa_perso_session

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_URL=https://huard-ai.example.com
LOG_LEVEL=INFO

# --- Base de données ---
DATABASE_URL=sqlite:///./data/huard_ai.db

# --- Sécurité ---
WEBHOOK_SECRET=change-me-to-a-long-random-string
